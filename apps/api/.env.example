# --- LLM ---
# Option 1 : OpenAI (payant, ~$0.0001/resume)
OPENAI_API_KEY=your_openai_api_key_here

# Option 2 : Ollama local (gratuit) — si OPENAI_API_KEY est vide, Ollama est utilise
# Installer Ollama : https://ollama.com  puis : ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Transcription ---
ALLOWED_ORIGINS=http://localhost:3000
WHISPER_MODEL=base
MAX_UPLOAD_SIZE_MB=50
MAX_CONCURRENT_TRANSCRIPTIONS=1
