# --- LLM (une seule clé suffit) ---

# Option 1 : Groq — gratuit, sans carte bleue, llama-3.3-70b
# Créer un compte : https://console.groq.com → API Keys
GROQ_API_KEY=

# Option 2 : OpenAI — payant (~$0.0001/résumé avec gpt-4o-mini)
OPENAI_API_KEY=

# Priorité : OpenAI > Groq. Si aucune clé → /api/summarize retourne 503.

# --- Transcription ---
ALLOWED_ORIGINS=http://localhost:3000
# Production : ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
WHISPER_MODEL=base
MAX_UPLOAD_SIZE_MB=50
MAX_CONCURRENT_TRANSCRIPTIONS=1
